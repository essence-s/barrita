import { Theme } from "../styles/theme.slint";

export component MusicIconWidget {
    in-out property <string> status: "stopped";
    in-out property <bool> has-player: false;
    
    callback play-pause();
    callback next();
    callback previous();
    
    Rectangle {
        opacity: root.has-player ? 1.0 : 0.5;
        
        HorizontalLayout {
            spacing: 4px;
            alignment: center;
            
            Text {
                text: root.has-player ? "music_note" : "music_off";
                font-family: Theme.icon-font-family;
                font-size: 16px;
                color: Theme.foreground;
            }
            
            TouchArea {
                clicked => { root.previous(); }
                Rectangle {
                    width: 20px;
                    height: 20px;
                    Text {
                        text: "skip_previous";
                        font-family: Theme.icon-font-family;
                        font-size: 16px;
                        color: Theme.foreground;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
            
            TouchArea {
                clicked => { root.play-pause(); }
                Rectangle {
                    width: 20px;
                    height: 20px;
                    Text {
                        text: root.status == "playing" ? "pause" : "play_arrow";
                        font-family: Theme.icon-font-family;
                        font-size: 16px;
                        color: Theme.accent;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
            
            TouchArea {
                clicked => { root.next(); }
                Rectangle {
                    width: 20px;
                    height: 20px;
                    Text {
                        text: "skip_next";
                        font-family: Theme.icon-font-family;
                        font-size: 16px;
                        color: Theme.foreground;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
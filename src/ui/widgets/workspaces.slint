import { Theme } from "../styles/theme.slint";

export component WorkspacesWidget {
    in-out property <int> active-workspace: 1;
    in-out property <int> total-workspaces: 8;
    in-out property <[bool]> workspace-occupied: [];

    private property <length> button-size: 18px;
    private property <length> button-spacing: 3px;
    private property <length> margin: 2px;

    Rectangle {
        vertical-stretch: 1;
        
        HorizontalLayout {
            alignment: center;

            VerticalLayout {
                alignment: center;

                Rectangle {
                    background: #252725d1;
                    border-radius: 12px;
                    
                    HorizontalLayout {
                        alignment: center;
                        spacing: 4px;
                        padding: 4px;
                        
                        for i in root.total-workspaces : Rectangle {
                            width: root.button-size;
                            height: root.button-size;
                            
                            private property <bool> occupied: 
                                i < root.workspace-occupied.length && 
                                root.workspace-occupied[i];
                            
                            private property <bool> active: 
                                i == root.active-workspace - 1;
                            
                            Rectangle {
                                x: 0;
                                y: 0;
                                width: root.button-size;
                                height: root.button-size;
                                border-radius: root.button-size / 2;
                                background: active ? Theme.accent : #00000000;
                                opacity: active ? 0.2 : 0.0;
                            }
                            
                            Rectangle {
                                x: 0;
                                y: 0;
                                width: root.button-size;
                                height: root.button-size;
                                border-radius: root.button-size / 2;
                                background: occupied ? #fdfdfda2 : #00000000;
                                opacity: occupied ? 0.3 : 0.0;
                            }
                            
                            Rectangle {
                                x: 3px;
                                y: 3px;
                                width: root.button-size - 6px;
                                height: root.button-size - 6px;
                                border-radius: root.button-size / 2 - 3px;
                                background: active ? Theme.accent : #00000000;
                            }
                            
                            Text {
                                text: i + 1;
                                font-size: 8px;
                                font-weight: active ? 700 : 400;
                                color: active ? 
                                    Theme.accent : 
                                    occupied ? 
                                        #ebf1eb : 
                                        #868686;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
        }
        }
    }
}